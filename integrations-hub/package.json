{
  "name": "creativeflow-integrations",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @creativeflow/db generate",
    "db:migrate": "pnpm --filter @creativeflow/db migrate",
    "db:seed": "pnpm --filter @creativeflow/db seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
